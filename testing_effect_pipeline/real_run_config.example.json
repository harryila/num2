{
    "dataset_path": "data/nq_open_train.jsonl",
    "steps": 25000,
    "batch_size": 16,
    "eval_every": 1000,
    "seeds": 3,
    "scheduler": "fsrs",
    "max_training_tokens": 500000,
    "require_budget": true,
    "methods": [
        "test_only",
        "test_reinforce",
        "retrieval_practice",
        "scheduled_restudy",
        "restudy_fixed_p10",
        "restudy_fixed_p25",
        "restudy_fixed_p50",
        "restudy_fixed_p75",
        "standard_ft",
        "random_replay",
        "curriculum",
        "loss_replay"
    ],
    "output": "artifacts/nq_real_experiment_metrics.json",

    "real": true,
    "model_name": "Qwen/Qwen2.5-1.5B-Instruct",
    "lora_r": 16,
    "lora_alpha": 32,
    "lr": 2e-4,
    "max_seq_len": 256,
    "max_new_tokens": 32,
    "grad_accum_steps": 4,
    "dtype": "bfloat16",
    "hf_token": null
}
